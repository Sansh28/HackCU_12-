# Root environment reference for the Savant monorepo.
# Copy values into the specific app env files under apps/backend, apps/frontend, and apps/extension.

# Backend
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/?retryWrites=true&w=majority
GEMINI_API_KEY=your_gemini_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
SOLANA_RPC_URL=https://api.devnet.solana.com
MASTER_WALLET=your_solana_receiver_wallet
QUERY_PRICE_SOL=0.005
PAYMENT_WINDOW_SECONDS=900
REQUIRE_SOLANA_PAYMENT=false
EMBED_MAX_RETRIES=6
EMBED_RETRY_BASE_SECONDS=1.0
EMBED_RETRY_MAX_SECONDS=20.0
EMBED_REQUEST_TIMEOUT_SECONDS=30
EMBED_MIN_INTERVAL_SECONDS=0.75
EMBED_ALLOW_LEXICAL_FALLBACK=true
GENERATE_MAX_RETRIES=4
GENERATE_RETRY_BASE_SECONDS=1.5
GENERATE_RETRY_MAX_SECONDS=45.0
ALLOW_GENERATE_LOCAL_FALLBACK=true
UPLOAD_CHUNK_SIZE=1400
UPLOAD_CHUNK_OVERLAP=200
UPLOAD_MAX_CHUNKS=120
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_MASTER_WALLET=your_solana_receiver_wallet
NEXT_PUBLIC_QUERY_PRICE_SOL=0.005
NEXT_PUBLIC_REQUIRE_SOLANA_PAYMENT=false

# Extension
VITE_SAVANT_API_BASE_URL=http://127.0.0.1:8000
